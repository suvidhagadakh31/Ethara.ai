{
  "info": {
    "name": "Team Task Manager API",
    "description": "Complete API collection for Team Task Manager application",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "token", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test123\",\n  \"role\": \"admin\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@taskmanager.com\",\n  \"password\": \"Admin123\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": ["const res = pm.response.json();", "if (res.token) pm.collectionVariables.set('token', res.token);"]
            }
          }]
        },
        {
          "name": "Get Current User",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        },
        {
          "name": "Get All Users",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/users" }
        }
      ]
    },
    {
      "name": "Projects",
      "item": [
        {
          "name": "Create Project",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Project\",\n  \"description\": \"Project description here\"\n}"
            }
          }
        },
        {
          "name": "Get All Projects",
          "request": { "method": "GET", "url": "{{baseUrl}}/projects" }
        },
        {
          "name": "Get Project by ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/projects/:id" }
        },
        {
          "name": "Update Project",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/projects/:id",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Title\",\n  \"description\": \"Updated description\"\n}"
            }
          }
        },
        {
          "name": "Delete Project",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/projects/:id" }
        },
        {
          "name": "Add Member to Project",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects/:id/members",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"<user_id_here>\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Task\",\n  \"description\": \"Task details\",\n  \"project\": \"<project_id>\",\n  \"priority\": \"high\",\n  \"dueDate\": \"2025-03-01\"\n}"
            }
          }
        },
        {
          "name": "Get Tasks (with filters)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/tasks?status=todo&priority=high&sort=dueDate&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["tasks"],
              "query": [
                { "key": "status", "value": "todo" },
                { "key": "priority", "value": "high" },
                { "key": "sort", "value": "dueDate" },
                { "key": "search", "value": "", "disabled": true },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/tasks/:id",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"in-progress\",\n  \"priority\": \"urgent\"\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/tasks/:id" }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Dashboard Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/dashboard/stats" }
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Register - Duplicate Email",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Dup\",\n  \"email\": \"admin@taskmanager.com\",\n  \"password\": \"Test123\"\n}" }
          }
        },
        {
          "name": "Login - Wrong Password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@taskmanager.com\",\n  \"password\": \"wrongpass\"\n}" }
          }
        },
        {
          "name": "Access Without Token",
          "request": { "method": "GET", "url": "{{baseUrl}}/projects", "auth": { "type": "noauth" } }
        },
        {
          "name": "Member Creates Project (403)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/projects",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Should Fail\"\n}" }
          }
        },
        {
          "name": "Invalid Task ID",
          "request": { "method": "GET", "url": "{{baseUrl}}/tasks/invalidid123" }
        },
        {
          "name": "Create Task - Missing Title",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"project\": \"<project_id>\"\n}" }
          }
        }
      ]
    }
  ]
}
